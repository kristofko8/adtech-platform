# ============================
# AdTech Platform - Environment
# ============================

# App
NODE_ENV=development
APP_PORT=3000
APP_SECRET=change_this_secret_in_production

# PostgreSQL
DATABASE_URL="postgresql://adtech:adtech_secret@localhost:5432/adtech_db?schema=public"

# ClickHouse
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_USER=adtech
CLICKHOUSE_PASSWORD=adtech_secret
CLICKHOUSE_DATABASE=analytics

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=adtech_secret

# Meta API
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_REDIRECT_URI=http://localhost:3000/auth/meta/callback
META_API_VERSION=v21.0
META_API_BASE_URL=https://graph.facebook.com

# JWT
JWT_SECRET=change_this_jwt_secret
JWT_EXPIRES_IN=7d

# S3 / MinIO
S3_ENDPOINT=http://localhost:9002
S3_ACCESS_KEY=adtech
S3_SECRET_KEY=adtech_secret_minio
S3_BUCKET_CREATIVES=adtech-creatives
S3_REGION=eu-central-1

# Slack (notifikácie)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Frontend URL (pre CORS)
FRONTEND_URL=http://localhost:4200
